# =============================================================================
# Paperless-ngx Umgebungsvariablen – Dokumentation für Coolify
# =============================================================================
# Diese Datei dient ausschließlich als Referenz/Dokumentation.
# Die Variablen werden NICHT aus dieser Datei gelesen, sondern direkt
# über die Coolify-Oberfläche (Environment Variables) gepflegt.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Datenbank
# -----------------------------------------------------------------------------
POSTGRES_DB=paperless
POSTGRES_USER=paperless
POSTGRES_PASSWORD=change-me          # PFLICHT – sicheres Passwort setzen!

# -----------------------------------------------------------------------------
# Paperless – Pflichtfelder
# -----------------------------------------------------------------------------
PAPERLESS_SECRET_KEY=change-me       # PFLICHT – langer, zufälliger String

# -----------------------------------------------------------------------------
# Paperless – Öffentliche URL (Reverse Proxy / Coolify Domain)
# -----------------------------------------------------------------------------
PAPERLESS_URL=https://paperless.example.com

# -----------------------------------------------------------------------------
# Paperless – Lokalisierung
# -----------------------------------------------------------------------------
PAPERLESS_TIME_ZONE=Europe/Berlin
PAPERLESS_OCR_LANGUAGE=deu       # Hauptsprache für OCR
PAPERLESS_OCR_LANGUAGES=             # Zusätzliche Sprachen (space-separated)

# -----------------------------------------------------------------------------
# Paperless – Container-Benutzer (UID/GID des Host-Users für Volumes)
# -----------------------------------------------------------------------------
USERMAP_UID=1000
USERMAP_GID=1000

# -----------------------------------------------------------------------------
# Paperless – Admin-Account (wird nur beim ersten Start angelegt)
# -----------------------------------------------------------------------------
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=change-me
PAPERLESS_ADMIN_MAIL=admin@example.com

# -----------------------------------------------------------------------------
# Datenbankverbindung – für externe DB (z. B. eigener Coolify-Container)
# Default: interner "db"-Container. Zum Auslagern einfach überschreiben:
# -----------------------------------------------------------------------------
PAPERLESS_DBHOST=db                  # Default: interner Service-Name "db"
PAPERLESS_DBPORT=5432                # Default: 5432

# Beispiel externe DB (eigener Coolify PostgreSQL-Container):
# PAPERLESS_DBHOST=postgresql-xxxxx.coolify.internal   (Coolify internal hostname)
# PAPERLESS_DBPORT=5432
# Den lokalen "db"-Service im compose-File dann einfach auskommentieren.

# -----------------------------------------------------------------------------
# Interne Service-Verbindungen (normalerweise nicht ändern)
# -----------------------------------------------------------------------------
# PAPERLESS_REDIS=redis://broker:6379
# PAPERLESS_TIKA_ENABLED=1
# PAPERLESS_TIKA_GOTENBERG_ENDPOINT=http://gotenberg:3000
# PAPERLESS_TIKA_ENDPOINT=http://tika:9998
